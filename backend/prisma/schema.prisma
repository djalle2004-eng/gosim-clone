generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =======================
// ENUMS
// =======================

enum KycStatus {
  PENDING
  APPROVED
  REJECTED
}

enum DocumentType {
  PASSPORT
  NATIONAL_ID
  DRIVERS_LICENSE
}

enum Role {
  USER
  ADMIN
  SUPER_ADMIN
  EMPLOYEE
  RESELLER
}

enum Currency {
  DZD
  USD
  EUR
}

enum Region {
  EUROPE
  ASIA
  AMERICAS
  AFRICA
  MIDDLEEAST
  GLOBAL
}

enum Speed {
  FOUR_G        @map("4G")
  FIVE_G        @map("5G")
  FOUR_G_FIVE_G @map("4G_5G")
}

enum PlanProvider {
  AIRALO
  ESIMGO
  SIMFONY
  CUSTOM
}

enum OrderStatus {
  PENDING
  PAID
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  CARD
  CIB
  EDAHABIA
}

enum EsimStatus {
  INACTIVE
  ACTIVE
  EXHAUSTED
  EXPIRED
  DELETED
}

enum PaymentProvider {
  STRIPE
  CIB
  EDAHABIA
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TenantPlan {
  FREE
  STARTER
  PRO
  ENTERPRISE
}

enum DiscountType {
  PERCENT
  FIXED
}

enum WalletTxType {
  TOPUP
  PURCHASE
  REFUND
  COMMISSION
  WITHDRAWAL
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  PAST_DUE
  TRIALING
}

// =======================
// MODELS
// =======================

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  password          String // hashed with bcrypt
  firstName         String?
  lastName          String?
  phone             String?
  avatar            String?
  country           String?
  preferredCurrency Currency  @default(USD)
  role              Role      @default(USER)
  isVerified        Boolean   @default(false)
  isActive          Boolean   @default(true)
  discountRate      Float     @default(0) // Percentage discount for RESELLER role (0 to 100)
  googleId          String?   @unique
  resetToken        String?
  resetTokenExpiry  DateTime?
  verifyToken       String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Tenant (multi-tenancy)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  orders         Order[]
  esims          ESim[]
  payments       Payment[]
  reviews        Review[]
  supportTickets SupportTicket[]
  ticketReplies  TicketReply[]
  notifications  Notification[]
  loginHistories LoginHistory[]
  auditLogs      AuditLog[]

  // RBAC Reseller link
  resellerId String?
  reseller   User?   @relation("ResellerClients", fields: [resellerId], references: [id])
  clients    User[]  @relation("ResellerClients")

  // Extended features
  kyc               IdentityVerification?
  wallet            Wallet?
  subscription      Subscription?
  referralCodes     ReferralCode[]
  referralsGiven    Referral[]            @relation("ReferrerUser")
  referralsReceived Referral[]            @relation("ReferredUser")
  apiKeys           ApiKey[]
  webhookEndpoints  WebhookEndpoint[]

  twoFactorSecret  String?
  twoFactorEnabled Boolean        @default(false)
  backupCodes      Json?
  refreshTokens    RefreshToken[]
  pushSubscriptions PushSubscription[]
  inAppNotifications InAppNotification[]

  @@index([email])
  @@index([role])
  @@index([tenantId])
  @@map("users")
}

model Country {
  id        String  @id @default(uuid())
  nameEn    String
  nameAr    String?
  code      String  @unique // ISO 3166-1 alpha-2
  flag      String? // emoji flag
  region    Region
  isPopular Boolean @default(false)
  isActive  Boolean @default(true)

  esimPlans ESimPlan[]

  @@index([region])
  @@index([isPopular])
  @@map("countries")
}

model ESimPlan {
  id         String   @id @default(uuid())
  name       String
  slug       String   @unique
  countryId  String?
  country    Country? @relation(fields: [countryId], references: [id])
  isGlobal   Boolean  @default(false)
  isRegional Boolean  @default(false)

  // Tenant (multi-tenancy)
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  // Data specs
  dataAmount Int // MB — use -1 for unlimited
  validity   Int // Days
  speed      Speed @default(FOUR_G)

  // Pricing (multi-currency)
  price    Float // USD
  priceDZD Float? // Algerian Dinar
  priceEUR Float? // Euro

  // Provider
  provider   PlanProvider @default(CUSTOM)
  providerId String? // External provider plan ID

  // Metadata
  features     Json? // e.g. ["Data Only", "No Phone Number", "Easy QR Setup"]
  isBestSeller Boolean @default(false)
  isUnlimited  Boolean @default(false)
  isActive     Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  reviews    Review[]

  @@index([countryId])
  @@index([tenantId])
  @@index([isActive, isBestSeller])
  @@index([provider])
  @@index([isGlobal, isRegional])
  @@map("esim_plans")
}

model Order {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  status      OrderStatus @default(PENDING)
  totalAmount Float
  currency    Currency    @default(USD)

  // Stripe
  stripePaymentIntentId String? @unique
  stripeSessionId       String? @unique

  paymentMethod PaymentMethod @default(CARD)
  notes         String?

  // Promo code applied
  promoCodeId String?
  promoCode   PromoCode? @relation(fields: [promoCodeId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orderItems OrderItem[]
  payments   Payment[]
  referrals  Referral[]

  @@index([userId])
  @@index([status])
  @@index([promoCodeId])
  @@map("orders")
}

model OrderItem {
  id      String   @id @default(uuid())
  orderId String
  order   Order    @relation(fields: [orderId], references: [id])
  planId  String
  plan    ESimPlan @relation(fields: [planId], references: [id])

  quantity   Int   @default(1)
  unitPrice  Float
  totalPrice Float

  assignedESims ESim[]

  @@index([orderId])
  @@index([planId])
  @@map("order_items")
}

model ESim {
  id          String    @id @default(uuid())
  orderItemId String
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id])
  userId      String
  user        User      @relation(fields: [userId], references: [id])

  iccid          String     @unique
  qrCode         String? // base64 encoded QR or URL
  activationCode String?
  status         EsimStatus @default(INACTIVE)

  dataUsed  Int @default(0) // MB consumed
  dataTotal Int // MB total

  activatedAt DateTime?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([userId])
  @@index([status])
  @@index([iccid])
  @@map("esims")
}

model Payment {
  id      String @id @default(uuid())
  orderId String
  order   Order  @relation(fields: [orderId], references: [id])
  userId  String
  user    User   @relation(fields: [userId], references: [id])

  amount   Float
  currency Currency @default(USD)

  provider              PaymentProvider @default(STRIPE)
  providerTransactionId String?
  status                PaymentStatus   @default(PENDING)
  metadata              Json? // raw provider response

  createdAt DateTime @default(now())

  @@index([orderId])
  @@index([userId])
  @@index([status])
  @@map("payments")
}

model Review {
  id     String   @id @default(uuid())
  userId String
  user   User     @relation(fields: [userId], references: [id])
  planId String
  plan   ESimPlan @relation(fields: [planId], references: [id])

  rating     Int // 1–5
  comment    String?
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@unique([userId, planId]) // one review per user per plan
  @@index([planId])
  @@map("reviews")
}

model SupportTicket {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  subject    String
  message    String         @db.Text
  status     TicketStatus   @default(OPEN)
  priority   TicketPriority @default(MEDIUM)
  assignedTo String? // admin userId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  replies TicketReply[]

  @@index([userId])
  @@index([status])
  @@map("support_tickets")
}

model Notification {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  type    String // ORDER | ESIM | PROMO | SYSTEM | SUPPORT
  title   String
  message String
  isRead  Boolean @default(false)
  data    Json? // optional extra payload

  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// =======================
// AUDIT & SECURITY MODELS
// =======================

model LoginHistory {
  id     String @id @default(uuid())
  userId String
  user   User   @relation(fields: [userId], references: [id])

  ip        String?
  device    String?
  userAgent String?
  success   Boolean

  createdAt DateTime @default(now())

  @@index([userId])
  @@map("login_histories")
}

model RefreshToken {
  id         String   @id @default(uuid())
  tokenHash  String   @unique
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt  DateTime
  deviceInfo String?
  ip         String?
  isRevoked  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model AuditLog {
  id      String @id @default(uuid())
  adminId String
  admin   User   @relation(fields: [adminId], references: [id])

  action   String // CREATE | UPDATE | DELETE | APPROVE | REJECT
  resource String // users | plans | orders | esims
  targetId String? // ID of the affected resource
  details  Json? // before/after snapshot

  createdAt DateTime @default(now())

  @@index([adminId])
  @@index([resource])
  @@map("audit_logs")
}

model IdentityVerification {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  documentType DocumentType
  documentUrl  String
  selfieUrl    String?
  status       KycStatus    @default(PENDING)
  adminNotes   String?      @db.Text

  submittedAt DateTime  @default(now())
  verifiedAt  DateTime?

  @@map("identity_verifications")
}

// =======================
// SYSTEM SETTINGS (API Keys Vault)
// =======================

model SystemSetting {
  id        String   @id @default(uuid())
  category  String // ESIM_PROVIDER, PAYMENT, EMAIL
  provider  String // AIRALO, ESIMGO, SIMFONY, STRIPE, CIB, EDAHABIA, SMTP
  key       String // CLIENT_ID, CLIENT_SECRET, API_KEY, etc.
  value     String   @db.Text // AES-256-GCM encrypted
  isActive  Boolean  @default(true)
  updatedBy String? // admin user ID who last modified
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, provider, key])
  @@index([category])
  @@index([provider])
  @@map("system_settings")
}

// =======================
// MULTI-TENANCY
// =======================

model Tenant {
  id             String     @id @default(uuid())
  slug           String     @unique
  name           String
  domain         String?    @unique
  logoUrl        String?
  primaryColor   String?    @default("#0ea5e9")
  secondaryColor String?    @default("#8b5cf6")
  plan           TenantPlan @default(FREE)
  isActive       Boolean    @default(true)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  users     User[]
  esimPlans ESimPlan[]

  @@index([slug])
  @@index([plan])
  @@map("tenants")
}

// =======================
// REFERRAL PROGRAM
// =======================

model ReferralCode {
  id             String       @id @default(uuid())
  code           String       @unique
  ownerId        String
  owner          User         @relation(fields: [ownerId], references: [id])
  usageCount     Int          @default(0)
  maxUsage       Int? // null = unlimited
  discountType   DiscountType
  discountValue  Float // percentage or fixed amount
  commissionRate Float        @default(0) // % of order given to referrer
  expiresAt      DateTime?
  isActive       Boolean      @default(true)
  createdAt      DateTime     @default(now())

  referrals Referral[]

  @@index([ownerId])
  @@index([code])
  @@map("referral_codes")
}

model Referral {
  id               String       @id @default(uuid())
  referralCodeId   String
  referralCode     ReferralCode @relation(fields: [referralCodeId], references: [id])
  referrerId       String
  referrer         User         @relation("ReferrerUser", fields: [referrerId], references: [id])
  referredUserId   String
  referredUser     User         @relation("ReferredUser", fields: [referredUserId], references: [id])
  orderId          String?
  order            Order?       @relation(fields: [orderId], references: [id])
  commissionAmount Float        @default(0)
  isPaid           Boolean      @default(false)
  createdAt        DateTime     @default(now())

  @@index([referralCodeId])
  @@index([referrerId])
  @@index([referredUserId])
  @@index([orderId])
  @@map("referrals")
}

// =======================
// DIGITAL WALLET
// =======================

model Wallet {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id])
  balance   Float    @default(0)
  currency  Currency @default(DZD)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(uuid())
  walletId    String
  wallet      Wallet       @relation(fields: [walletId], references: [id])
  type        WalletTxType
  amount      Float
  description String?
  referenceId String? // orderId, referralId, etc.
  createdAt   DateTime     @default(now())

  @@index([walletId])
  @@index([type])
  @@index([createdAt])
  @@map("wallet_transactions")
}

// =======================
// SUBSCRIPTIONS
// =======================

model Subscription {
  id                   String             @id @default(uuid())
  userId               String             @unique
  user                 User               @relation(fields: [userId], references: [id])
  planTier             TenantPlan
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  stripeSubscriptionId String?            @unique
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  @@index([status])
  @@index([planTier])
  @@map("subscriptions")
}

// =======================
// API PARTNER PROGRAM
// =======================

model ApiKey {
  id         String    @id @default(uuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id])
  name       String
  keyHash    String    @unique // SHA-256 hash of the actual key
  prefix     String    @db.VarChar(8) // First 8 chars shown to user
  scopes     Json // ["orders:read", "plans:read", "esims:write", ...]
  lastUsedAt DateTime?
  expiresAt  DateTime?
  isActive   Boolean   @default(true)
  createdAt  DateTime  @default(now())

  @@index([userId])
  @@index([keyHash])
  @@map("api_keys")
}

model WebhookEndpoint {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  url       String
  events    Json // ["order.completed", "esim.activated", ...]
  secret    String // HMAC signing secret
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  deliveries WebhookDelivery[]

  @@index([userId])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id        String          @id @default(uuid())
  webhookId String
  webhook   WebhookEndpoint @relation(fields: [webhookId], references: [id])
  event     String
  payload   Json
  status    DeliveryStatus  @default(PENDING)
  attempts  Int             @default(0)
  nextRetry DateTime?
  response  Json?
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@index([webhookId])
  @@index([status, nextRetry])
  @@map("webhook_deliveries")
}

enum DeliveryStatus {
  PENDING
  SUCCESS
  FAILED
}

// =======================
// SUPPORT TICKET REPLIES
// =======================

model TicketReply {
  id           String        @id @default(uuid())
  ticketId     String
  ticket       SupportTicket @relation(fields: [ticketId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  message      String        @db.Text
  isStaffReply Boolean       @default(false)
  createdAt    DateTime      @default(now())

  @@index([ticketId])
  @@index([userId])
  @@map("ticket_replies")
}

// =======================
// PROMO CODES
// =======================

model PromoCode {
  id                String       @id @default(uuid())
  code              String       @unique
  discountType      DiscountType
  discountValue     Float
  minOrderAmount    Float? // minimum cart value to apply
  maxUses           Int? // null = unlimited
  currentUses       Int          @default(0)
  applicablePlanIds Json? // null = applies to all plans
  expiresAt         DateTime?
  isActive          Boolean      @default(true)
  createdAt         DateTime     @default(now())

  orders Order[]

  @@index([code])
  @@index([isActive])
  @@map("promo_codes")
}

// =======================
// PUSH SUBSCRIPTIONS
// =======================

model PushSubscription {
  id           String   @id @default(uuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subscription Json     // Full PushSubscription object from browser
  userAgent    String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@map("push_subscriptions")
}

// =======================
// IN-APP NOTIFICATIONS
// =======================

enum NotificationCategory {
  ORDER
  ESIM
  PAYMENT
  SYSTEM
  PROMOTION
}

model InAppNotification {
  id        String               @id @default(uuid())
  userId    String
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  body      String
  category  NotificationCategory @default(SYSTEM)
  url       String?
  isRead    Boolean              @default(false)
  createdAt DateTime             @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("in_app_notifications")
}

